<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.futinfor.controller.NoticiaController"
      style="-fx-padding: 20;">

    <Label text="Gerenciamento de Notícias"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TextField fx:id="txtTitulo"
               promptText="Título" />

    <TextArea fx:id="txtConteudo"
              promptText="Conteúdo"
              prefHeight="100"/>

    <HBox spacing="10" alignment="CENTER">
    <Button fx:id="btnSalvar" text="Salvar" onAction="#handleSalvar" style="-fx-background-color: #4caf50; -fx-text-fill: white;" prefWidth="100"/>
    <Button fx:id="btnAtualizar" text="Atualizar" onAction="#handleAtualizar" style="-fx-background-color: #2196f3; -fx-text-fill: white;" prefWidth="100"/>
    <Button fx:id="btnDeletar" text="Deletar" onAction="#handleDeletar" style="-fx-background-color: #f44336; -fx-text-fill: white;" prefWidth="100"/>
    </HBox>

    <TableView fx:id="tabelaNoticias" prefHeight="300">

        <columns>

            <TableColumn fx:id="colTitulo"
                         text="Título"
                         prefWidth="250"/>

            <TableColumn fx:id="colAutor"
                         text="Autor"
                         prefWidth="150"/>
            
            <TableColumn fx:id="colConteudo"
                         text="Conteúdo"
                         prefWidth="350"/>  

            <TableColumn fx:id="colDataPublicacao"
                         text="Data Publicação"
                         prefWidth="150"/>

        </columns>

    </TableView>

</VBox>