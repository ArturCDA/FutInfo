<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.futinfor.controller.PartidaController"
      alignment="TOP_CENTER"
      style="-fx-padding: 20;">

    <Label text="Cadastro de Partidas"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10">
     
    <TextField fx:id="txtTimeCasaId" promptText="Time Casa ID" />

    <TextField fx:id="txtTimeForaId" promptText="Time Fora ID" />

    <TextField fx:id="txtEstadio" promptText="Estádio" />

    <DatePicker fx:id="dpData" promptText="Data da Partida" />
    </HBox>

    <HBox spacing="10">
        <Button text="Salvar" onAction="#salvar"/>
        <Button text="Atualizar" onAction="#atualizar"/>
        <Button text="Deletar" onAction="#deletar"/>
    </HBox>

    <TableView fx:id="tabelaPartidas" VBox.vgrow="ALWAYS" prefHeight="400">
    <columns>
        <TableColumn fx:id="colId" text="ID" prefWidth="60" />
        <TableColumn fx:id="colCasa" text="Time Casa ID" prefWidth="120" />
        <TableColumn fx:id="colFora" text="Time Fora ID" prefWidth="120" />
        <TableColumn fx:id="colEstadio" text="Estádio" prefWidth="200" />
        <TableColumn fx:id="colDataHora" text="Data da Partida" prefWidth="150" />
    </columns>
    </TableView>

</VBox>