<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.futinfor.controller.MainController">

    <left>
        <VBox spacing="10" alignment="TOP_CENTER"
              style="-fx-padding: 20; -fx-background-color: #2c3e50; -fx-pref-width: 220;">

            <Label text="Menu" 
                   style="-fx-text-fill: white; -fx-font-size: 18px; -fx-padding: 10;"/>

            <Button fx:id="btnNoticias" text="Notícias" 
                    onAction="#abrirNoticias" 
                    style="-fx-pref-width: 180; -fx-font-size: 14px;"/>

            <Button fx:id="btnUsuarios" text="Usuários" 
                    onAction="#abrirUsuarios" 
                    style="-fx-pref-width: 180; -fx-font-size: 14px;"/>

            <Button fx:id="btnTimes" text="Times" 
                    onAction="#abrirTimes" 
                    style="-fx-pref-width: 180; -fx-font-size: 14px;"/>

            <Button fx:id="btnPartidas" text="Partidas" 
                    onAction="#abrirPartidas" 
                    style="-fx-pref-width: 180; -fx-font-size: 14px;"/>

        </VBox>
    </left>

    <center>
    <AnchorPane fx:id="conteudoArea" 
                style="-fx-background-color: #f8f9fa;"  
                prefWidth="900.0" prefHeight="600.0">
       
    </AnchorPane>
</center>

</BorderPane>