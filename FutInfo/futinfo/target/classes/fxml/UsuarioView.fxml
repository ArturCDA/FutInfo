<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.futinfor.controller.UsuarioController"
      alignment="TOP_CENTER"
      style="-fx-padding: 20;">

    <Label text="Cadastro de Usuários"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <HBox spacing="10">
        <TextField fx:id="txtNome" promptText="Nome"/>
        <TextField fx:id="txtEmail" promptText="Email"/>
        <PasswordField fx:id="txtSenha" promptText="Senha"/>
        <ComboBox fx:id="cbTipo" promptText="Tipo"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Salvar" onAction="#salvar"/>
        <Button text="Atualizar" onAction="#atualizar"/>
        <Button text="Deletar" onAction="#deletar"/>
    </HBox>

    <TableView fx:id="tabelaUsuarios" prefHeight="300">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colNome" text="Nome" prefWidth="150"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
            <TableColumn fx:id="colTipo" text="Tipo" prefWidth="120"/>
        </columns>
    </TableView>

</VBox>